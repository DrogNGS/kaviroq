{
  "expo": {
    "name": "Kaviroq",
    "slug": "kaviroq",
    "owner": "drogon10",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kaviroq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drogon10.kaviroq",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kaviroq utilise votre position pour vous localiser sur la carte et vous montrer les restaurants à proximité."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.drogon10.kaviroq",
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kaviroq utilise votre position pour vous localiser sur la carte et vous montrer les restaurants à proximité."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b001e9b9-8b50-443b-9495-97e4ea2e3771"
      }
    }
  }
}