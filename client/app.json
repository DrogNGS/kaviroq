  },
  "package": "com.drogon10.kaviroq",
  "edgeToEdgeEnabled": true,
  "googleServicesFile": "./google-services.json"
  },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-web-browser"
    ],
    "extra": {
