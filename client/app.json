{
  "expo": {
    "name": "Kaviroq",
    "slug": "kaviroq",
    "owner": "drogon10",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kaviroq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drogon10.kaviroq"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.drogon10.kaviroq",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "b001e9b9-8b50-443b-9495-97e4ea2e3771"
      }
    }
  }
}